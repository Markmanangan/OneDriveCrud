@page "/"
@using Microsoft.EntityFrameworkCore
@using EmployeeAPI.Models
@using EmployeeAPI.Data
@inject IDbContextFactory<EmployeeAPIContext> DbFactory

<PageTitle>Employees</PageTitle>

<div class="container py-4">

    <!-- Header -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
        <h1 class="h3 fw-bold mb-0">
            <i class="bi bi-people-fill text-primary me-2"></i>
            Employees
        </h1>
        <span class="badge bg-primary-subtle text-primary fw-semibold px-3 py-2 rounded-pill">
            @(employees?.Count ?? 0) total
        </span>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center py-5">
            <div class="spinner-border text-primary"></div>
        </div>
    }
    else if (employees?.Count == 0)
    {
        <!-- Empty state -->
        <div class="text-center py-5">
            <i class="bi bi-people display-4 text-muted mb-3"></i>
            <h5 class="text-muted">No employees yet</h5>
            <p class="text-muted small">Once you add employees, they will appear here.</p>
        </div>
    }
    else
    {
        <!-- Card wrapper -->
        <div class="card border-0 shadow-sm rounded-4">
            <div class="table-responsive">
                <table class="table align-middle table-hover mb-0">

                    <!-- Light header (cleaner than dark) -->
                    <thead class="bg-light">
                        <tr class="text-muted small">
                            <th class="ps-4">Employee ID</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th class="text-end pe-4">Location</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var emp in employees!)
                        {
                            <tr class="employee-row">
                                <td class="ps-4 fw-semibold text-muted">
                                    EMP-@emp.Id.ToString("D4")
                                </td>

                                <!-- Name (primary) -->
                                <td>
                                    <div class="fw-semibold text-dark">
                                        @emp.Name
                                    </div>
                                </td>

                                <!-- Email -->
                                <td>
                                    <div class="text-muted small">
                                        @emp.Email
                                    </div>
                                </td>

                                <!-- Phone -->
                                <td>
                                    <i class="bi bi-telephone-fill text-success me-2"></i>
                                    <span class="fw-medium">
                                        @emp.Phone
                                    </span>
                                </td>

                                <!-- Location -->
                                <td class="text-end pe-4">
                                    <span class="badge bg-light text-dark fw-medium px-3 py-2 rounded-pill">
                                        @emp.Location
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>
        </div>
    }

</div>

<style>
    /* Row hover effect */
    .employee-row:hover {
        background-color: #f8f9fa;
        transition: background-color 0.15s ease-in-out;
    }

    /* Improve table spacing */
    table td, table th {
        padding-top: 1rem;
        padding-bottom: 1rem;
    }
</style>

@code {
    private List<Employee>? employees;
    private bool isLoading;

    protected override async Task OnInitializedAsync()
    {
        await LoadEmployeesAsync();
    }

    private async Task LoadEmployeesAsync()
    {
        try
        {
            isLoading = true;

            using var context = DbFactory.CreateDbContext();
            employees = await context.Employee
                                     .AsNoTracking()
                                     .OrderByDescending(e => e.Id)
                                     .ToListAsync();
        }
        finally
        {
            isLoading = false;
        }
    }
}