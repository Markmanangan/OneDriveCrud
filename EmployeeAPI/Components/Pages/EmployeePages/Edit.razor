@page "/employees/edit"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Forms
@using EmployeeAPI.Models
@inject IDbContextFactory<EmployeeAPI.Data.EmployeeAPIContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Edit Employee</PageTitle>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <div class="d-flex align-items-center">
                        <i class="fas fa-user-edit me-3"></i>
                        <h4 class="card-title mb-0">Edit Employee</h4>
                    </div>
                </div>
                <div class="card-body p-4">
                    @if (isLoading)
                    {
                        <div class="text-center py-5">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <p class="mt-3 mb-0">Loading employee details...</p>
                        </div>
                    }
                    else if (Employee is null)
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-exclamation-triangle text-warning mb-3" style="font-size: 3rem;"></i>
                            <h5 class="text-muted">Employee not found</h5>
                            <a href="/employees" class="btn btn-outline-primary mt-3">Back to List</a>
                        </div>
                    }
                    else
                    {
                        <EditForm Model="Employee" OnValidSubmit="UpdateEmployee" Enhance>
                            <DataAnnotationsValidator />
                            <ValidationSummary role="alert" class="alert alert-danger mb-4" />

                            <div class="row mb-4">
                                <div class="col-md-6 mb-4">
                                    <label for="Name" class="form-label fw-bold">Name <span class="text-danger">*</span></label>
                                    <InputText id="Name" @bind-Value="Employee.Name" class="form-control form-control-lg" />
                                    <ValidationMessage For="() => Employee.Name" class="text-danger mt-1" />
                                </div>
                                <div class="col-md-6 mb-4">
                                    <label for="Email" class="form-label fw-bold">Email</label>
                                    <InputText id="Email" @bind-Value="Employee.Email" class="form-control form-control-lg" />
                                    <ValidationMessage For="() => Employee.Email" class="text-danger mt-1" />
                                </div>
                                <div class="col-md-6 mb-4">
                                    <label for="Phone" class="form-label fw-bold">Phone <span class="text-danger">*</span></label>
                                    <InputText id="Phone" @bind-Value="Employee.Phone" class="form-control form-control-lg" />
                                    <ValidationMessage For="() => Employee.Phone" class="text-danger mt-1" />
                                </div>
                                <div class="col-md-6 mb-4">
                                    <label for="Location" class="form-label fw-bold">Location <span class="text-danger">*</span></label>
                                    <InputText id="Location" @bind-Value="Employee.Location" class="form-control form-control-lg" />
                                    <ValidationMessage For="() => Employee.Location" class="text-danger mt-1" />
                                </div>
                            </div>

                            <div class="d-flex gap-3 justify-content-center pt-3">
                                <button type="submit" class="btn btn-outline-primary btn-lg px-5" disabled="@isSaving">
                                    <i class="fas @(isSaving ? "fa-spinner fa-spin me-2" : "fa-save me-2")"></i>
                                    @(isSaving ? "Saving..." : "Save Changes")
                                </button>
                                <a href="/employees" class="btn btn-outline-secondary btn-lg px-5">
                                    <i class="fas fa-arrow-left me-2"></i> Cancel
                                </a>
                            </div>
                        </EditForm>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    private long Id { get; set; }

    private Employee? Employee { get; set; }
    private bool isLoading = true;
    private bool isSaving = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            using var context = DbFactory.CreateDbContext();
            Employee = await context.Employee.FirstOrDefaultAsync(m => m.Id == Id);

            if (Employee is null)
            {
                // Stay on page instead of redirect
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Load error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task UpdateEmployee()
    {
        if (isSaving || Employee is null) return;

        isSaving = true;

        try
        {
            using var context = DbFactory.CreateDbContext();
            var dbEmp = await context.Employee.FindAsync(Employee.Id);

            if (dbEmp == null)
            {
                // Employee deleted by someone else
                NavigationManager.NavigateTo("/employees", forceLoad: true);
                return;
            }

            // Update fields
            dbEmp.Name = Employee.Name;
            dbEmp.Email = Employee.Email;
            dbEmp.Phone = Employee.Phone;
            dbEmp.Location = Employee.Location;

            await context.SaveChangesAsync();
            NavigationManager.NavigateTo("/employees");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Save error: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }
}