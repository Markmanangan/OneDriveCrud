@page "/employees"
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Forms
@using EmployeeAPI.Models
@inject IDbContextFactory<EmployeeAPI.Data.EmployeeAPIContext> DbFactory

<PageTitle>Employees</PageTitle>

<div class="container mt-4">

    <!-- ✅ Header (matches Home) -->
    <div class="mb-4">
        <h2 class="fw-bold mb-2">Employees</h2>

        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
            <!-- Search -->
            <input class="form-control"
                   style="width: 260px;"
                   placeholder="Search employees…"
                   @bind="SearchText"
                   @bind:event="oninput" />

            <!-- Add -->
            <button class="btn btn-primary"
                    @onclick="OpenCreate">
                Add Employee
            </button>
        </div>
    </div>

    <!-- ✅ Table -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="table-responsive">
            <table class="table align-middle table-hover mb-0">

                <thead class="bg-light">
                    <tr class="text-muted small">
                        <th class="ps-4">Employee ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th class="text-end pe-4">Location</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var emp in PagedEmployees)
                    {
                        <tr class="employee-row">

                            <td class="ps-4 employee-id">
                                EMP-@emp.Id.ToString("D4")
                            </td>

                            <td>
                                <div class="fw-semibold text-dark">@emp.Name</div>
                            </td>

                            <td>
                                <div class="text-muted small">@emp.Email</div>
                            </td>

                            <td>
                                <i class="bi bi-telephone-fill text-success me-2"></i>
                                <span class="fw-medium">@emp.Phone</span>
                            </td>

                            <td class="text-end pe-4">
                                <span class="badge bg-light text-dark fw-medium px-3 py-2 rounded-pill">
                                    @emp.Location
                                </span>
                            </td>

                            <td class="text-center">
                                <div class="btn-group btn-group-sm">
                                    <button class="btn btn-outline-success"
                                            @onclick="() => OpenView(emp)">
                                        View
                                    </button>
                                    <button class="btn btn-outline-primary"
                                            @onclick="() => OpenEdit(emp)">
                                        Edit
                                    </button>
                                    <button class="btn btn-outline-danger"
                                            @onclick="() => AskDelete(emp)">
                                        Delete
                                    </button>
                                </div>
                            </td>

                        </tr>
                    }
                </tbody>

            </table>
        </div>
    </div>

    <!-- Pagination -->
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= TotalPages; i++)
            {
                <li class="page-item @(Page == i ? "active" : "")">
                    <button class="page-link"
                            @onclick="() => Page = i">
                        @i
                    </button>
                </li>
            }
        </ul>
    </nav>

</div>

<!-- ✅ CREATE / EDIT / VIEW MODAL -->
@if (ShowModal)
{
    <div class="modal fade show d-block" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">@ModalTitle</h5>
                    <button class="btn-close" @onclick="CloseModal"></button>
                </div>

                <div class="modal-body">
                    @if (ModalMode == Mode.View)
                    {
                        <dl>
                            <dt>Name</dt>
                            <dd>@Current.Name</dd>
                            <dt>Email</dt>
                            <dd>@Current.Email</dd>
                            <dt>Phone</dt>
                            <dd>@Current.Phone</dd>
                            <dt>Location</dt>
                            <dd>@Current.Location</dd>
                        </dl>
                    }
                    else
                    {
                        <EditForm Model="Current" OnValidSubmit="Save">
                            <DataAnnotationsValidator />

                            <div class="mb-2">
                                <label>Name</label>
                                <InputText class="form-control" @bind-Value="Current.Name" />
                            </div>

                            <div class="mb-2">
                                <label>Email</label>
                                <InputText class="form-control" @bind-Value="Current.Email" />
                            </div>

                            <div class="mb-2">
                                <label>Phone</label>
                                <InputText class="form-control" @bind-Value="Current.Phone" />
                            </div>

                            <div class="mb-2">
                                <label>Location</label>
                                <InputText class="form-control" @bind-Value="Current.Location" />
                            </div>

                            <div class="text-end mt-3">
                                <button type="button"
                                        class="btn btn-secondary me-2"
                                        @onclick="CloseModal">
                                    Cancel
                                </button>
                                <button class="btn btn-primary" type="submit">
                                    Save
                                </button>
                            </div>
                        </EditForm>
                    }
                </div>

            </div>
        </div>
    </div>
}

<!-- ✅ DELETE CONFIRMATION MODAL -->
@if (ShowDeleteConfirm && DeleteTarget != null)
{
    <div class="modal fade show d-block" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button class="btn-close btn-close-white"
                            @onclick="CancelDelete"></button>
                </div>

                <div class="modal-body">
                    Are you sure you want to delete
                    <strong>@DeleteTarget.Name</strong>?
                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary"
                            @onclick="CancelDelete">
                        Cancel
                    </button>
                    <button class="btn btn-danger"
                            @onclick="ConfirmDelete">
                        Delete
                    </button>
                </div>

            </div>
        </div>
    </div>
}

<!-- ✅ CONSISTENT CSS -->
<style>
    .employee-row:hover {
        background-color: #f8f9fa;
        transition: background-color .15s ease-in-out;
    }

    table td, table th {
        padding-top: 1rem;
        padding-bottom: 1rem;
        vertical-align: middle;
    }

    .employee-id {
        font-family: Consolas, "Courier New", monospace;
        font-size: .9rem;
        letter-spacing: .05em;
        color: #6c757d;
        white-space: nowrap;
        width: 140px;
    }
</style>

@code {

    private List<Employee> employees = new();
    private Employee Current = new();
    private Employee? DeleteTarget;

    private bool ShowModal;
    private bool ShowDeleteConfirm;

    enum Mode { Create, Edit, View }
    private Mode ModalMode;

    private int Page = 1;
    private int PageSize = 10;

    private string searchText = "";
    private string SearchText
    {
        get => searchText;
        set { searchText = value; Page = 1; }
    }

    private IEnumerable<Employee> Filtered =>
        employees.Where(e =>
            string.IsNullOrWhiteSpace(searchText)
            || e.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase)
            || e.Email.Contains(searchText, StringComparison.OrdinalIgnoreCase)
            || e.Phone.Contains(searchText, StringComparison.OrdinalIgnoreCase)
            || e.Location.Contains(searchText, StringComparison.OrdinalIgnoreCase)
            || e.Id.ToString().Contains(searchText)
            || $"EMP-{e.Id:D4}".Contains(searchText, StringComparison.OrdinalIgnoreCase)
        );

    private IEnumerable<Employee> PagedEmployees =>
        Filtered.Skip((Page - 1) * PageSize).Take(PageSize);

    private int TotalPages =>
        Math.Max(1, (int)Math.Ceiling(Filtered.Count() / (double)PageSize));

    protected override async Task OnInitializedAsync()
        => await Load();

    private async Task Load()
    {
        using var db = DbFactory.CreateDbContext();
        employees = await db.Employee
            .AsNoTracking()
            .OrderByDescending(e => e.Id)
            .ToListAsync();
    }

    private void OpenCreate() { Current = new(); ModalMode = Mode.Create; ShowModal = true; }
    private void OpenEdit(Employee e) { Current = new Employee { Id = e.Id, Name = e.Name, Email = e.Email, Phone = e.Phone, Location = e.Location }; ModalMode = Mode.Edit; ShowModal = true; }
    private void OpenView(Employee e) { Current = e; ModalMode = Mode.View; ShowModal = true; }
    private void CloseModal() => ShowModal = false;

    private void AskDelete(Employee e) { DeleteTarget = e; ShowDeleteConfirm = true; }
    private void CancelDelete() { DeleteTarget = null; ShowDeleteConfirm = false; }

    private async Task ConfirmDelete()
    {
        if (DeleteTarget == null) return;
        using var db = DbFactory.CreateDbContext();
        db.Employee.Remove(DeleteTarget);
        await db.SaveChangesAsync();
        await Load();
        Page = 1;
        CancelDelete();
    }

    private async Task Save()
    {
        using var db = DbFactory.CreateDbContext();

        if (ModalMode == Mode.Create)
            db.Employee.Add(Current);
        else
        {
            var existing = await db.Employee.FindAsync(Current.Id);
            if (existing is null) return;

            existing.Name = Current.Name;
            existing.Email = Current.Email;
            existing.Phone = Current.Phone;
            existing.Location = Current.Location;
        }

        await db.SaveChangesAsync();
        await Load();
        Page = 1;
        CloseModal();
    }

    private string ModalTitle => ModalMode switch
    {
        Mode.Create => "Add Employee",
        Mode.Edit => "Edit Employee",
        Mode.View => "Employee Details",
        _ => ""
    };
}