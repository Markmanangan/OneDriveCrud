@page "/employees"
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Forms
@using EmployeeAPI.Models
@inject IDbContextFactory<EmployeeAPI.Data.EmployeeAPIContext> DbFactory

<PageTitle>Employees</PageTitle>

<div class="container mt-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Employees</h2>
        <button class="btn btn-primary" @onclick="OpenCreate">
            Add Employee
        </button>
    </div>

    <!-- Search -->
    <input class="form-control w-25 mb-3"
           placeholder="Search..."
           @bind="SearchText"
           @bind:event="oninput" />

    <!-- Table -->
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th class="ps-4">Employee ID</th>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Location</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var emp in PagedEmployees)
            {
                <tr>

                    <td class="ps-4 fw-semibold text-muted">
                        EMP-@emp.Id.ToString("D4")
                    </td>

                    <td>@emp.Name</td>
                    <td>@emp.Email</td>
                    <td>@emp.Phone</td>
                    <td>@emp.Location</td>
                    <td class="text-center">
                        <div class="btn-group btn-group-sm">
                            <button class="btn btn-outline-success"
                                    @onclick="() => OpenView(emp)">
                                View
                            </button>
                            <button class="btn btn-outline-primary"
                                    @onclick="() => OpenEdit(emp)">
                                Edit
                            </button>
                            <button class="btn btn-outline-danger"
                                    @onclick="() => AskDelete(emp)">
                                Delete
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <!-- Pagination -->
    <nav>
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= TotalPages; i++)
            {
                <li class="page-item @(Page == i ? "active" : "")">
                    <button class="page-link"
                            @onclick="() => Page = i">
                        @i
                    </button>
                </li>
            }
        </ul>
    </nav>
</div>

<!-- Create / Edit / View Modal -->
@if (ShowModal)
{
    <div class="modal fade show d-block" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">@ModalTitle</h5>
                    <button class="btn-close" @onclick="CloseModal"></button>
                </div>

                <div class="modal-body">
                    @if (ModalMode == Mode.View)
                    {
                        <dl>
                            <dt>Name</dt>
                            <dd>@Current.Name</dd>
                            <dt>Email</dt>
                            <dd>@Current.Email</dd>
                            <dt>Phone</dt>
                            <dd>@Current.Phone</dd>
                            <dt>Location</dt>
                            <dd>@Current.Location</dd>
                        </dl>
                    }
                    else
                    {
                        <EditForm Model="Current" OnValidSubmit="Save">
                            <DataAnnotationsValidator />

                            <div class="mb-2">
                                <label>Name</label>
                                <InputText class="form-control"
                                           @bind-Value="Current.Name" />
                            </div>

                            <div class="mb-2">
                                <label>Email</label>
                                <InputText class="form-control"
                                           @bind-Value="Current.Email" />
                            </div>

                            <div class="mb-2">
                                <label>Phone</label>
                                <InputText class="form-control"
                                           @bind-Value="Current.Phone" />
                            </div>

                            <div class="mb-2">
                                <label>Location</label>
                                <InputText class="form-control"
                                           @bind-Value="Current.Location" />
                            </div>

                            <div class="text-end mt-3">
                                <button type="button"
                                        class="btn btn-secondary me-2"
                                        @onclick="CloseModal">
                                    Cancel
                                </button>
                                <button class="btn btn-primary"
                                        type="submit">
                                    Save
                                </button>
                            </div>
                        </EditForm>
                    }
                </div>
            </div>
        </div>
    </div>
}

<!-- Delete Confirmation Modal -->
@if (ShowDeleteConfirm && DeleteTarget != null)
{
    <div class="modal fade show d-block" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button class="btn-close btn-close-white"
                            @onclick="CancelDelete"></button>
                </div>

                <div class="modal-body">
                    Are you sure you want to delete
                    <strong>@DeleteTarget.Name</strong>?
                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary"
                            @onclick="CancelDelete">
                        Cancel
                    </button>
                    <button class="btn btn-danger"
                            @onclick="ConfirmDelete">
                        Delete
                    </button>
                </div>

            </div>
        </div>
    </div>
}

@code {

    // ===== STATE =====
    private List<Employee> employees = new();
    private Employee Current = new();
    private Employee? DeleteTarget;

    private bool ShowModal;
    private bool ShowDeleteConfirm;

    enum Mode { Create, Edit, View }
    private Mode ModalMode;

    // ===== SEARCH & PAGING =====
    private int Page = 1;
    private int PageSize = 10;

    private string searchText = "";
    private string SearchText
    {
        get => searchText;
        set
        {
            searchText = value;
            Page = 1; // ✅ reset ONLY on search
        }
    }

    private IEnumerable<Employee> Filtered =>
        employees.Where(e =>
            string.IsNullOrWhiteSpace(searchText)

            // ✅ Search by Name, Email, Phone, Location
            || e.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase)
            || e.Email.Contains(searchText, StringComparison.OrdinalIgnoreCase)
            || e.Phone.Contains(searchText, StringComparison.OrdinalIgnoreCase)
            || e.Location.Contains(searchText, StringComparison.OrdinalIgnoreCase)
           
            || e.Id.ToString().Contains(searchText)

            || $"EMP-{e.Id:D4}".Contains(searchText, StringComparison.OrdinalIgnoreCase)
        );

    private IEnumerable<Employee> PagedEmployees =>
        Filtered.Skip((Page - 1) * PageSize).Take(PageSize);

    private int TotalPages =>
        Math.Max(1, (int)Math.Ceiling(Filtered.Count() / (double)PageSize));

    // ===== LIFECYCLE =====
    protected override async Task OnInitializedAsync()
        => await Load();

    private async Task Load()
    {
        using var db = DbFactory.CreateDbContext();

        // ✅ Newest records FIRST
        employees = await db.Employee
            .AsNoTracking()
            .OrderByDescending(e => e.Id)
            .ToListAsync();
    }

    // ===== CRUD =====
    private void OpenCreate()
    {
        Current = new Employee();
        ModalMode = Mode.Create;
        ShowModal = true;
    }

    private void OpenEdit(Employee e)
    {
        Current = new Employee
        {
            Id = e.Id,
            Name = e.Name,
            Email = e.Email,
            Phone = e.Phone,
            Location = e.Location
        };

        ModalMode = Mode.Edit;
        ShowModal = true;
    }

    private void OpenView(Employee e)
    {
        Current = new Employee
        {
            Name = e.Name,
            Email = e.Email,
            Phone = e.Phone,
            Location = e.Location
        };

        ModalMode = Mode.View;
        ShowModal = true;
    }

    private async Task Save()
    {
        using var db = DbFactory.CreateDbContext();

        if (ModalMode == Mode.Create)
        {
            db.Employee.Add(Current);
        }
        else
        {
            var existing = await db.Employee.FindAsync(Current.Id);
            if (existing == null) return;

            existing.Name = Current.Name;
            existing.Email = Current.Email;
            existing.Phone = Current.Phone;
            existing.Location = Current.Location;
        }

        await db.SaveChangesAsync();
        await Load();

        Page = 1;       // ✅ show newest record
        CloseModal();
    }

    // ===== DELETE =====
    private void AskDelete(Employee emp)
    {
        DeleteTarget = emp;
        ShowDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        ShowDeleteConfirm = false;
        DeleteTarget = null;
    }

    private async Task ConfirmDelete()
    {
        if (DeleteTarget == null) return;

        using var db = DbFactory.CreateDbContext();
        var existing = await db.Employee.FindAsync(DeleteTarget.Id);

        if (existing != null)
        {
            db.Employee.Remove(existing);
            await db.SaveChangesAsync();
        }

        await Load();
        Page = 1;       // ✅ avoid empty page after delete
        CancelDelete();
    }

    private void CloseModal()
    {
        ShowModal = false;
    }

    private string ModalTitle => ModalMode switch
    {
        Mode.Create => "Add Employee",
        Mode.Edit => "Edit Employee",
        Mode.View => "Employee Details",
        _ => ""
    };
}