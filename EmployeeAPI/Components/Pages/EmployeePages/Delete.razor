@page "/employees/delete"
@using Microsoft.EntityFrameworkCore
@using EmployeeAPI.Models
@inject IDbContextFactory<EmployeeAPI.Data.EmployeeAPIContext> DbFactory
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Delete Employee</PageTitle>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-danger text-white">
                    <div class="d-flex align-items-center">
                        <i class="fas fa-exclamation-triangle me-3"></i>
                        <h4 class="card-title mb-0">Delete Employee</h4>
                    </div>
                </div>
                <div class="card-body p-4">
                    @if (isLoading)
                    {
                        <div class="text-center py-5">
                            <div class="spinner-border text-danger" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <p class="mt-3 mb-0">Loading employee details...</p>
                        </div>
                    }
                    else if (employee is null)
                    {
                        <div class="alert alert-warning text-center" role="alert">
                            <i class="fas fa-user-slash me-2"></i>
                            <strong>Employee not found!</strong>
                            <a href="/employees" class="btn btn-outline-warning mt-3">Go to Employees</a>
                        </div>
                    }
                    else if (deleteSuccess)
                    {
                        <div class="text-center py-5">
                            <div class="alert alert-success mb-4" role="alert">
                                <i class="fas fa-check-circle fa-3x text-success mb-3 d-block"></i>
                                <h3 class="mb-3">Employee Deleted Successfully!</h3>
                                <p class="lead mb-4">@employee.Name has been permanently deleted.</p>
                            </div>
                            <a href="/employees" class="btn btn-success btn-lg px-4">
                                <i class="fas fa-list me-2"></i>
                                View All Employees
                            </a>
                        </div>
                    }
                    else if (deleteError)
                    {
                        <div class="alert alert-danger mb-4" role="alert">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            <strong>Error deleting employee.</strong> Please try again.
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-danger mb-4" role="alert">
                            <i class="fas fa-exclamation-circle me-2"></i>
                            <strong>Are you sure?</strong> This action cannot be undone. This will permanently delete:
                            <strong class="d-block mt-1">@employee.Name</strong>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Name:</label>
                                <div class="form-control-plaintext bg-light p-3 rounded">@employee.Name</div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Email:</label>
                                <div class="form-control-plaintext bg-light p-3 rounded">@employee.Email</div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Phone:</label>
                                <div class="form-control-plaintext bg-light p-3 rounded">@employee.Phone</div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Location:</label>
                                <div class="form-control-plaintext bg-light p-3 rounded">@employee.Location</div>
                            </div>
                        </div>

                        <!-- FIXED: Added FormName="delete" -->
                        <EditForm Model="employee" OnValidSubmit="DeleteEmployee" FormName="delete">
                            <DataAnnotationsValidator />
                            <div class="d-flex gap-2 justify-content-center pt-3">
                                <button type="submit"
                                        class="btn btn-danger btn-lg px-4"
                                        disabled="@(isDeleting)">
                                    @if (isDeleting)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                        <span>Deleting...</span>
                                    }
                                    else
                                    {
                                        <i class="fas fa-trash me-2"></i>
                                        <span>Delete Employee</span>
                                    }
                                </button>
                                <a href="/employees" class="btn btn-outline-secondary btn-lg px-4">
                                    <i class="fas fa-arrow-left me-2"></i>
                                    Cancel
                                </a>
                            </div>
                        </EditForm>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private Employee? employee;
    private bool isLoading = true;
    private bool isDeleting = false;
    private bool deleteSuccess = false;
    private bool deleteError = false;

    [SupplyParameterFromQuery]
    private long Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            using var context = DbFactory.CreateDbContext();
            employee = await context.Employee.FirstOrDefaultAsync(m => m.Id == Id);
        }
        catch (Exception)
        {
            // Handle DB errors gracefully
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (deleteSuccess)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("alert", "Employee deleted successfully!");
                NavigationManager.NavigateTo("/employees");
            }
            catch
            {
                // Fallback navigation if JS fails
                NavigationManager.NavigateTo("/employees");
            }
        }
        else if (deleteError)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("alert", "Error deleting employee. Please try again.");
            }
            catch
            {
                // Silent fail for alert
            }
        }
    }

    private async Task DeleteEmployee()
    {
        if (employee is null) return;

        isDeleting = true;
        deleteError = false;
        deleteSuccess = false;
        StateHasChanged();

        try
        {
            using var context = DbFactory.CreateDbContext();
            context.Employee.Remove(employee);
            await context.SaveChangesAsync();

            deleteSuccess = true;
            isDeleting = false;
            StateHasChanged();
        }
        catch (Exception)
        {
            deleteError = true;
            isDeleting = false;
            StateHasChanged();
        }
    }
}

<style>
    .card-header {
        border-bottom: 0 !important;
    }

    .form-control-plaintext {
        border: 1px solid #dee2e6;
        font-weight: 500;
    }

    .btn-lg {
        min-width: 140px;
    }
</style>